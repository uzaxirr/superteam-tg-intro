# Telegram Bot Token from @BotFather
BOT_TOKEN=

# Main group chat ID (negative number for groups, e.g. -1001234567890)
MAIN_GROUP_ID=

# Intro channel/group chat ID where users post introductions
INTRO_CHANNEL_ID=

# Comma-separated Telegram user IDs for admin access
ADMIN_IDS=

# Optional: minimum intro message length
MIN_INTRO_LENGTH=50
